{
  "name": "releaser",
  "version": "0.0.0",
  "type": "module",
  "description": "GitHub Action that creates version tags and releases based on PR labels",
  "private": true,
  "packageManager": "pnpm@9.15.0",
  "scripts": {
    "build": "tsc",
    "bundle": "ncc build src/index.ts -o dist --license licenses.txt",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "@actions/core": "^3.0.0",
    "@actions/github": "^9.0.0",
    "semver": "^7.7.4"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.5.0",
    "@types/semver": "^7.7.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^10.0.3",
    "prettier": "^3.8.1",
    "typescript": "^5.9.3",
    "typescript-eslint": "^8.57.0",
    "vite": "^8.0.0",
    "vitest": "^4.1.0"
  }
}
